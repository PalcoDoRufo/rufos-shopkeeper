    <aside class="resumo">
        <h1>- Resumo da Venda -</h1>
        <section class="venda">
            <ul>
                {{#each resumo}}
                <li class="itemResumo">
                    <div class="linha1">
                        <img src="{{item.img}}">
                        <span>{{item.name}}</span>
                    </div>
                    <div class="linha2">
                        <span class="vazio"></span>
                        <span><i>[{{vendedor}}]</i></span>
                        <span>x{{quantity}}</span>
                        <span>{{valorTexto}}</span>
                    </div>
                </li>
                {{/each}}
            </ul>
            <div class="resumo">
                <div class="total-box">
                    <span>Total</span>
                    <strong>{{valorTotalTexto}}</strong>
                </div>

                <div class="player-box">
                    <span>Por player</span>
                    <strong>{{valorPorJogadorTexto}}</strong>
                </div>
            </div>
        </section>
    </aside>
