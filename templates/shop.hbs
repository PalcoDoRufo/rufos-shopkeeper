<div class="lojinha">
    <aside class="pjCheck">
        <img src="modules/rufos-shopkeeper/assets/Stash.webp" class="portrait">
        <ul>
            {{#each personagensAside}}
            <li><input type="checkbox" class="pjCheckbox" data-actor="{{id}}" {{#if checked}}checked{{/if}}> <span
                    class="markName">{{name}}</span></li>
            {{/each}}
        </ul>
    </aside>
    <main class="meio">
        <header class="pjTabs">
            <button class="tabsPj" data-tab="stash">Stash</button>
            {{#each personagens}}
            <button class="tabsPj" data-tab="{{id}}">{{name}}</button>
            {{/each}}
        </header>
        <div class="centro">
            <section class="rufo exibindo" id="rufo">
                <img src="modules/rufos-shopkeeper/assets/RufosShopkeeper.webp" alt="shopkeeper">
            </section>
            <section class="inventario" data-inventario="stash">
                <div class="itemType">
                    <header class="itemHeader">
                        <h3 class="itemTitle">Weapons & Shields</h3 class="itemTitle">
                        <div class="quantidade">Quantidade</div>
                        <div class="valor">Valor</div>
                    </header>
                    <div class="itemTable">
                        <ul>
                            {{#each stash.weapons}}
                            <li class="itemLinha">
                                <input type="checkbox" class="itemCheckbox" data-uuid="{{item.uuid}}" data-name="Stash"
                                    {{#if checked}}checked{{/if}}>
                                <img src="{{item.img}}">
                                <span class="itemName">{{item.name}}</span>
                                <div class="quantias">
                                    <button class="menosUm">-</button>
                                    <span class="itemQuantity" data-max="{{item.system.quantity}}"
                                        data-uuid="{{item.uuid}}">{{quantity}}</span>
                                    <button class="maisUm">+</button>
                                </div>
                                <span class="itemValue">{{item.system.price.value}}</span>
                            </li>
                            {{/each}}
                            {{#each stash.shields}}
